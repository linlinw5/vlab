# Server
PORT=8800
NODE_ENV=development
# NODE_ENV=production
# NODE_ENV=test

# HTTPS WebSocket proxy (for ESXi console access)
BUILTIN_PROXY_ENABLED=true
BUILTIN_PROXY_PORT=8843
BUILTIN_PROXY_LABEL=Builtin proxy

NGINX_PROXY_ENABLED=false
NGINX_PROXY_PORT=443
NGINX_PROXY_LABEL=Nginx proxy

# SSL cert paths (only used when BUILTIN_PROXY_ENABLED=true)
SSL_KEY_PATH=./cert/private.key
SSL_CERT_PATH=./cert/certificate.crt

# JWT - Seconds: 900=15min, 604800=7days
JWT_ACCESS_SECRET=your_jwt_access_secret_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here
JWT_ACCESS_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=604800

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vlab
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# vCenter
VCENTER_BASE_URL=https://your.vcenter.host
VCENTER_USERNAME=your_vcenter_user@domain
VCENTER_PASSWORD=your_vcenter_password_here
VCENTER_CATEGORY_NAME=vlab-category

# Cisco ASA (leave blank to disable VPN provisioning)
ASA_HOST=your.asa.host
ASA_PORT=22
ASA_USERNAME=asa_admin_user
ASA_PASSWORD=your_asa_password_here

# VMware folder IDs
VM_FOLDER_SOURCE=group-v81
VM_FOLDER_TARGET=group-v82

# Default admin account (auto-created on first startup)
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=your_admin_password_here

# CORS — set to your frontend origin
CORS_ORIGIN=http://localhost:3000
