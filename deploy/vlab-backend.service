[Unit]
Description=VLab Backend (Express)
After=network.target

[Service]
Type=simple
User=vlab
Group=vlab

WorkingDirectory=/opt/vlab/backend
ExecStart=/usr/bin/node --enable-source-maps dist/server.js
Restart=on-failure
RestartSec=5

# stdout/stderr go to journald; view with: journalctl -u vlab-backend -f
StandardOutput=journal
StandardError=journal
SyslogIdentifier=vlab-backend

[Install]
WantedBy=multi-user.target
